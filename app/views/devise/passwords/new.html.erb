<h2></h2>
<div class="col-md-4 offset-4 m-5-auto mt-5 ">
<div class="card bg-primary mb-3" style="color: white;" >
  <div class="card-header">Forgot your password?</div>
  <div class="card-body">
    <h4 class="card-title">Reset</h4>
<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="field">
    <%= f.label :email %><br />
    <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
  </div>
<br>
  <div class="actions">
    <%= f.submit "Reset password", class: "btn btn-success" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
</div>
</div>
</div>